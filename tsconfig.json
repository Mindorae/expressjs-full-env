{
    "compilerOptions": {
        "typeRoots": [
            "./src/types",
            "./node_modules/@types"
        ],
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*"
    ]
}